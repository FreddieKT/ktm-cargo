# SECURITY: Never commit your real .env file to version control.
# If you suspect credentials have been exposed, rotate them immediately:
#   - Supabase: Dashboard → Project Settings → API → Regenerate anon key
#   - Sentry: Settings → Projects → Client Keys → Revoke & recreate DSN
#   - LogRocket: Settings → Apps → Regenerate App ID
#
# Supabase (required). Use Vite names below; dashboard may show Next.js names.
# Get from: Supabase Dashboard → Project Settings → API (or "Connect" → API Keys).
# - Project URL        → VITE_SUPABASE_URL (e.g. https://xxxx.supabase.co)
# - anon public key OR publishable key (browser-safe) → VITE_SUPABASE_ANON_KEY
VITE_SUPABASE_URL=your_project_url_here
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# Monitoring (optional)
VITE_SENTRY_DSN=your_sentry_dsn_here
VITE_LOGROCKET_APP_ID=your_logrocket_app_id_here

# Stripe (optional — for subscription/billing features)
# Get from: Stripe Dashboard → Developers → API Keys
# Use the PUBLISHABLE key here (pk_live_… or pk_test_…). Never the secret key.
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
# The STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET go into Supabase Edge
# Function secrets only (via `supabase secrets set`). See DEPLOYMENT.md.
